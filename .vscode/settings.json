{
  "cmake.generator": "Ninja",
  "cmake.preferredGenerators": [
    "Ninja"
  ],
  "cmake.buildDirectory": "${workspaceFolder}/build-linux-debug",
  "cmake.configureSettings": {
    "CMAKE_BUILD_TYPE": "Debug",
    "CMAKE_EXPORT_COMPILE_COMMANDS": true
  },
  "coverage-gutters.lcovname": "build-linux-debug/lcov.info",
  "coverage-gutters.showGutterCoverage": true,
  "coverage-gutters.showLineCoverage": true,
  "clangd.path": "/usr/bin/clangd",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build-linux-debug"
  ],
  "editor.inlayHints.enabled": "on",
  "C_Cpp.inlayHints.parameterNames.enabled": "all",
  "C_Cpp.inlayHints.parameterNames.suppressWhenArgumentContainsName": false
}
