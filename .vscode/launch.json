{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Fairlanes",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/src/fairlanes",
      "args": [],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "stopAtEntry": false,

      // This is the important bit for a terminal app:
      "console": "integratedTerminal",

      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
