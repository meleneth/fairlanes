{
  "name": "fairlanes-linux-trixie",
  "image": "debian:trixie",

  "postCreateCommand": ".devcontainer/post_create.sh",

  "forwardPorts": [8086],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "llvm-vs-code-extensions.vscode-clangd",
        ".devcontainer/extensions/ftxui-color-swatch-0.0.1.vsix"
      ]
    }
  }
}
